# AzureLIT — Terraform variable environment file
#
# Usage (with direnv — recommended):
#   1. Copy this file: cp infra/example.env infra/.env
#   2. Fill in the values below
#   3. From the repo root run: direnv allow
#   direnv will auto-export these as TF_VAR_* on directory entry.
#   See docs/DEPLOYMENT_SUMMARY.md for full direnv setup instructions.
#
# Usage (without direnv):
#   source infra/.env   # NOTE: requires no 'export' prefix — direnv's dotenv
#                       # builtin handles bare KEY=VALUE files natively.
#                       # For plain `source`, prefix each line with `export `.
#
# Generate a secure master key:
#   openssl rand -base64 48 | tr -d "=+/" | cut -c1-64

TF_VAR_subscription_id=your-azure-subscription-id
TF_VAR_litellm_master_key=your-secure-master-key-here

# Comma-separated client API keys validated by custom_auth.py
# Generate keys: openssl rand -base64 32 | tr -d "=+/" | cut -c1-40 | sed 's/^/sk-/'
# The master key above is also accepted — no need to duplicate it here.
TF_VAR_api_keys=sk-key1,sk-key2

# =============================================================================
# BUDGET CONFIGURATION (Required)
# =============================================================================
# Azure Consumption Budget monitors costs and sends email alerts.
# Alerts trigger at 50%, 80%, and 100% of the monthly limit.

# Required: Comma-separated list of email addresses for budget alerts
TF_VAR_budget_alert_emails=admin@company.com,devops@company.com

# Optional: Monthly budget limit in EUR (default: 100)
# TF_VAR_budget_monthly_amount=500

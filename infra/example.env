# LiteLLM Master Key Configuration
# Copy this file to .env and set your secure master key
# 
# To generate a new secure master key, run:
# openssl rand -base64 48 | tr -d "=+/" | cut -c1-64
#
# This key is used for authenticating requests to the LiteLLM proxy
# Keep this secure and rotate it periodically

TF_VAR_litellm_master_key=your-secure-master-key-here
TF_VAR_foundry_api_base=https://<account>.services.ai.azure.com
TF_VAR_foundry_project=AzureLIT-Project
TF_VAR_foundry_api_key=your-foundry-project-key
TF_VAR_foundry_api_version=2024-05-01-preview